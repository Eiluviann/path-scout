{
  "name": "@path-scout/core",
  "version": "0.0.7",
  "description": "Core library for path-scout — trie-based URL routing and plugin system",
  "private": false,
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ]
}
