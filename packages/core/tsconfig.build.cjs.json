{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/cjs",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": false,
    "composite": false,
    "declaration": false,
    "declarationMap": false
  },
  "exclude": ["src/**/*.test.ts", "src/__tests__"]
}
