{
  "name": "path-scout",
  "version": "0.0.7",
  "description": "CLI for path-scout — a fast browser bookmark redirector",
  "private": false,
  "type": "module",
  "license": "AGPL-3.0-only",
  "main": "./dist/index.js",
  "bin": {
    "path-scout": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^1.19.14",
    "@path-scout/core": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "static"
  ]
}
